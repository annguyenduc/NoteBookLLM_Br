# 1. Ignore everything by default
/*

# 2. Root files
!/.gitignore
!/README.md
!/AGENTS.md
!/CONTINUITY.md
!/SOUL.md
!/USER.md
!/WORKSPACE_OVERVIEW.md
!/.gitattributes
!/notebook-learning.code-workspace
!/notebook-dev.code-workspace
!/notebook-source.code-workspace
!/notebook-research.code-workspace

# Compatibility shim only. Real libs live under workspaces/dev-lab/libs.
!/libs/
!/libs/__init__.py

# 3. Core vault directories
!/00_Inbox/
/00_Inbox/*
!/00_Inbox/.gitkeep
!/00_Inbox/gap_candidates/
!/00_Inbox/gap_candidates/**

!/1-projects/
!/1-projects/**

!/2-areas/
!/2-areas/**

!/3-resources/
!/3-resources/**

!/workspaces/
/workspaces/*
!/workspaces/README.md
!/workspaces/*/
/workspaces/*/*
!/workspaces/*/README.md
!/workspaces/*/AGENTS.md
!/workspaces/*/*/
/workspaces/*/*/*
!/workspaces/*/*/.gitkeep
!/workspaces/*/.vscode/
!/workspaces/*/.vscode/settings.json
!/workspaces/dev-lab/scripts/
!/workspaces/dev-lab/scripts/**
!/workspaces/dev-lab/tools/
!/workspaces/dev-lab/tools/**
!/workspaces/dev-lab/libs/
!/workspaces/dev-lab/libs/**
!/workspaces/dev-lab/tests/
!/workspaces/dev-lab/tests/**
!/workspaces/dev-lab/sandbox/
/workspaces/dev-lab/sandbox/*
!/workspaces/dev-lab/sandbox/.gitkeep
!/workspaces/learning/dashboard/
!/workspaces/learning/dashboard/**

# 4. Agent/runtime control files
!/.agent/
!/.agent/**

!/.codex/
!/.codex/agents/
!/.codex/agents/*.toml

!/scripts/
!/scripts/**

!/runs/
!/runs/**

# 5. Re-ignore heavy/runtime outputs
/3-resources/wiki/wiki_brain.db
/3-resources/wiki/wiki_brain.db-journal
/3-resources/wiki/log.md

/runs/ingest_*/
/runs/tmp_*/
/runs/cache_*/

!/runs/.gitkeep
!/runs/README.md

# 6. Python/cache
**/__pycache__/
**/*.pyc
**/.env
**/*.log
**/cache/**
**/output/**
