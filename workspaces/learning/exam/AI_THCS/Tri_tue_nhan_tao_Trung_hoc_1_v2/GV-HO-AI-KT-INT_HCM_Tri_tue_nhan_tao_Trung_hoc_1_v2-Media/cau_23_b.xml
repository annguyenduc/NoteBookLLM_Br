<xml xmlns="http://www.w3.org/1999/xhtml">
    <variables>
      <variable type="" id="q23_var_smile" islocal="false" iscloud="false">Số lần cười</variable>
    </variables>
    <block type="event_whenflagclicked" id="q23_b_start" x="150" y="150">
      <next>
        <block type="data_setvariableto" id="q23_b_init">
          <field name="VARIABLE" id="q23_var_smile" variabletype="">Số lần cười</field>
          <value name="VALUE">
            <shadow type="text" id="init_val_b">
              <field name="TEXT">0</field>
            </shadow>
          </value>
          <next>
            <block type="poseFace_videoToggle" id="q23_b_video">
              <value name="VIDEO_STATE">
                <shadow type="poseFace_menu_VIDEO_STATE" id="video_val_b">
                  <field name="VIDEO_STATE">on</field>
                </shadow>
              </value>
              <next>
                <block type="control_forever" id="q23_b_forever">
                  <statement name="SUBSTACK">
                    <block type="control_if" id="q23_b_if">
                      <value name="CONDITION">
                        <block type="poseFace_affdexIsExpression" id="q23_b_smile">
                          <value name="EXPRESSION">
                            <shadow type="poseFace_menu_EXPRESSION" id="expr_val_b1">
                              <field name="EXPRESSION">smile</field>
                            </shadow>
                          </value>
                        </block>
                      </value>
                      <statement name="SUBSTACK">
                        <block type="data_changevariableby" id="q23_b_change">
                          <field name="VARIABLE" id="q23_var_smile" variabletype="">Số lần cười</field>
                          <value name="VALUE">
                            <shadow type="math_number" id="change_val_b">
                              <field name="NUM">1</field>
                            </shadow>
                          </value>
                          <next>
                            <block type="control_wait_until" id="q23_b_wait">
                              <value name="CONDITION">
                                <block type="operator_not" id="q23_b_not">
                                  <value name="OPERAND">
                                    <block type="poseFace_affdexIsExpression" id="q23_b_smile_check">
                                      <value name="EXPRESSION">
                                        <shadow type="poseFace_menu_EXPRESSION" id="expr_val_b2">
                                          <field name="EXPRESSION">smile</field>
                                        </shadow>
                                      </value>
                                    </block>
                                  </value>
                                </block>
                              </value>
                            </block>
                          </next>
                        </block>
                      </statement>
                    </block>
                  </statement>
                </block>
              </next>
            </block>
          </next>
        </block>
      </next>
    </block>
  </xml>